OWNER_ID = 7783086532
SUDO_FILE = "sudo.json"

if os.path.exists(SUDO_FILE):
    with open(SUDO_FILE) as f: sudo_users = set(json.load(f))
else: sudo_users = {OWNER_ID}

def save_sudo():
    with open(SUDO_FILE, "w") as f: json.dump(list(sudo_users), f)

DESTROY_TEXTS = [
    "Kya?? 😂😂 Teri???😂😂😂 Maa???? 😂😂😂😂 Randy????? 😂😂😂😂😂",
    "▒░✍️ teri maa ki chudai me maja aya ▒░✍️",
