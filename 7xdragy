NC_PREFIX = "ƇӇƲƤ ƦƝƊƳƘƎ"
NC_FILL = "𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫𒐫"
NC_EXTRA = ["💩","😂","🔥","💀","🤡","👊","🖕","🐶","🤯","😈","👹","👺"]

REACT_EMOJI = "🤣"

destroy_name = None; destroy_active = False
attack_id = None; custom_text = None
gcname_text = None; gcname_active = False
spam_text = None; spam_active = False
react_id = None
bot_apps = []

def ok(u): return u in sudo_users

async def init_bots():
    global bot_apps
    for t in TOKENS:
        try:
            app = Application.builder().token(t).build()
            await app.initialize()
            bot_apps.append(app)
        except: pass
    print(f"ULTRON ONLINE — {len(bot_apps)}/12 bots")

async def all_msg(chat_id, text, reply=None):
    async def send(app):
        try: await app.bot.send_message(chat_id, text, reply_to_message_id=reply)
        except: pass
    await asyncio.gather(*[send(a) for a in bot_apps])

async def all_react(chat_id, msg_id):
    await asyncio.gather(*[a.bot.set_message_reaction(chat_id, msg_id, REACT_EMOJI) for a in bot_apps], return_exceptions=True)

async def menu(update, context):
    await update.message.reply_text("""⚡ ULTRON
/destroy /stopdestruction
/attack /stopattack
/reply /spam
/gcname /stopgcname
/react /stopreact
/sudo /takesudo /sudolist
/check /stopall /menu""")

async def destroy(update, context):
    global destroy_name, destroy_active
    if not ok(update.effective_user.id): return
    if not context.args: return
    destroy_name = context.args[0]; destroy_active = True
    asyncio.create_task(destroy_loop(update.effective_chat.id))
    await update.message.reply_text(f"⚡ {destroy_name} marked for destruction.")

async def destroy_loop(chat_id):
    while destroy_active and destroy_name:
        await all_msg(chat_id, f"{destroy_name} {random.choice(DESTROY_TEXTS)}")
        await asyncio.sleep(0.02)

async def stopdestruction(update, context):
    global destroy_active, destroy_name
    if not ok(update.effective_user.id): return
    if destroy_active:
        await update.message.reply_text(f"⚡ {destroy_name} spared. For now.")
        destroy_active = False

async def attack(update, context):
    global attack_id
    if not ok(update.effective_user.id): return
    if not update.message.reply_to_message: return
    attack_id = update.message.reply_to_message.from_user.id
    await update.message.reply_text(f"⚡ Target locked.")

async def stopattack(update, context):
    global attack_id
    if not ok(update.effective_user.id): return
    if attack_id:
        await update.message.reply_text("⚡ Target released.")
        attack_id = None

async def reply_cmd(update, context):
    global custom_text, attack_id
    if not ok(update.effective_user.id): return
    if not context.args: return
    custom_text = " ".join(context.args)
    if update.message.reply_to_message:
        attack_id = update.message.reply_to_message.from_user.id
        await update.message.reply_text(f"⚡ Reply set. Target locked.")

async def spam(update, context):
    global spam_text, spam_active
    if not ok(update.effective_user.id): return
    if not update.message.reply_to_message or not update.message.reply_to_message.text: return
    spam_text = update.message.reply_to_message.text; spam_active = True
    asyncio.create_task(spam_loop(update.effective_chat.id))
    await update.message.reply_text("⚡ Spam initiated.")

async def spam_loop(chat_id):
    while spam_active and spam_text:
        await all_msg(chat_id, spam_text)

async def gcname(update, context):
    global gcname_text, gcname_active
    if not ok(update.effective_user.id): return
    if not context.args: return
    gcname_text = " ".join(context.args); gcname_active = True
    asyncio.create_task(gcname_loop(update.effective_chat.id))
    await update.message.reply_text("⚡ GC name warping...")

async def gcname_loop(chat_id):
    i = 0
    while gcname_active and gcname_text:
        tasks = []
        for j, bot in enumerate(bot_apps):
            extra = NC_EXTRA[(i + j) % len(NC_EXTRA)]
            base = f"{gcname_text} {NC_PREFIX} {NC_FILL}"
            remaining = 255 - len(base)
            if remaining > 0:
                full_extra = (extra * ((remaining // len(extra)) + 1))[:remaining]
            else:
                full_extra = ""
            title = (base + full_extra)[:255]
            tasks.append(bot.bot.set_chat_title(chat_id, title))
        await asyncio.gather(*tasks, return_exceptions=True)
        i += 1
        await asyncio.sleep(0.5)

async def stopgcname(update, context):
    global gcname_active
    if not ok(update.effective_user.id): return
    gcname_active = False
    await update.message.reply_text("⚡ GC name frozen.")

async def react(update, context):
    global react_id
    if not ok(update.effective_user.id): return
    if not context.args: return
    react_id = int(context.args[0])
    await update.message.reply_text(f"⚡ Reacting to {react_id}.")

async def stopreact(update, context):
    global react_id
    if not ok(update.effective_user.id): return
    react_id = None
    await update.message.reply_text("⚡ Reactions halted.")

async def stopall(update, context):
    global destroy_active, attack_id, gcname_active, spam_active, react_id
    if not ok(update.effective_user.id): return
    destroy_active = attack_id = gcname_active = spam_active = False; react_id = None
    await update.message.reply_text("⚡ All systems terminated.")

async def check(update, context):
    await all_msg(update.effective_chat.id, "⚡")
    await update.message.reply_text(f"⚡ Fleet: {len(bot_apps)}/12 operational.")

async def sudo(update, context):
    if update.effective_user.id != OWNER_ID: return
    if context.args:
        sudo_users.add(int(context.args[0])); save_sudo()
        await update.message.reply_text("⚡ Access granted.")

async def takesudo(update, context):
    if update.effective_user.id != OWNER_ID: return
    if context.args:
        uid = int(context.args[0])
        if uid != OWNER_ID: sudo_users.discard(uid); save_sudo()
        await update.message.reply_text("⚡ Access revoked.")

async def sudolist(update, context):
    await update.message.reply_text(f"⚡ Sudo: {sudo_users}")

async def handler(update, context):
    global attack_id, custom_text, react_id
    if not update.message or not update.message.from_user: return
    chat_id = update.effective_chat.id; user_id = update.message.from_user.id; msg_id = update.message.message_id
    if react_id and user_id == react_id: await all_react(chat_id, msg_id)
    if attack_id and user_id == attack_id:
        text = custom_text if custom_text else random.choice(DESTROY_TEXTS)
        await all_msg(chat_id, text, msg_id)

def main():
    loop = asyncio.new_event_loop()
    asyncio.set_event_loop(loop)
    loop.run_until_complete(init_bots())
    app = Application.builder().token(TOKENS[0]).build()
    for c in [menu, destroy, stopdestruction, attack, stopattack, reply_cmd, spam, gcname, stopgcname, react, stopreact, stopall, check, sudo, takesudo, sudolist]:
        app.add_handler(CommandHandler(c.__name__.replace('_cmd',''), c) if c == reply_cmd else CommandHandler(c.__name__, c))
    app.add_handler(CommandHandler("reply", reply_cmd))
    app.add_handler(MessageHandler(filters.ALL, handler))
    app.run_polling(allowed_updates=Update.ALL_TYPES, drop_pending_updates=True)

if __name__ == "__main__":
    main()
